# Copy to .env.local — public values only (NEXT_PUBLIC_*)

NEXT_PUBLIC_NOCAP_REGISTRY=0x
NEXT_PUBLIC_HACKATHON_REGISTRY=0x
NEXT_PUBLIC_NOCAP_BADGE=0x
NEXT_PUBLIC_DEPLOYMENT_BLOCK=0
# HackathonRegistry deploy block (if it was deployed separately/later than the main registry)
NEXT_PUBLIC_HACKATHON_DEPLOYMENT_BLOCK=0
NEXT_PUBLIC_RPC_URL=https://testnet-rpc.monad.xyz
# Optional: a dedicated eth_getLogs-only endpoint (e.g. Envio's HyperRPC) for
# scanning event history fast. Public testnet RPC hard-caps eth_getLogs at 100
# blocks; a HyperRPC-style provider scoped to one contract can cover this app's
# entire chain history in ~200ms instead of tens of seconds. Falls back to
# NEXT_PUBLIC_RPC_URL if unset. Never used for contract reads or wallet writes —
# HyperRPC doesn't implement eth_call/eth_estimateGas/eth_sendRawTransaction.
NEXT_PUBLIC_SCAN_RPC_URL=

# owner/repo of THIS project on GitHub — powers the landing page's self-referential
# "dogfooding" link once this repo is registered + anchored. Leave blank until then.
NEXT_PUBLIC_SELF_REPO=

NEXT_PUBLIC_RELAYER_ADDRESS=0x
# URL-friendly App name from its GitHub settings page — powers the "Connect GitHub"
# button's install link (github.com/apps/<slug>/installations/new). Public, not secret.
NEXT_PUBLIC_GITHUB_APP_SLUG=

# --- Server-only below: no NEXT_PUBLIC_ prefix, read only by app/api/** routes. ---
NOCAP_RELAYER_PRIVATE_KEY=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
