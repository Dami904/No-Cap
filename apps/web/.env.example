# Copy to .env.local — public values only (NEXT_PUBLIC_*)

NEXT_PUBLIC_NOCAP_REGISTRY=0x
NEXT_PUBLIC_HACKATHON_REGISTRY=0x
NEXT_PUBLIC_NOCAP_BADGE=0x
NEXT_PUBLIC_DEPLOYMENT_BLOCK=0
# HackathonRegistry deploy block (if it was deployed separately/later than the main registry)
NEXT_PUBLIC_HACKATHON_DEPLOYMENT_BLOCK=0
NEXT_PUBLIC_RPC_URL=https://testnet-rpc.monad.xyz

# Envio HyperIndex GraphQL endpoint. When set, the app reads event history
# (anchors, projects, hackathon windows) from the indexed database instead of
# scanning eth_getLogs — instant lists, no RPC rate limits, no provider token in
# the browser. Leave blank to fall back to direct log scanning. Deploy the
# indexer in indexer/ (see indexer/DEPLOY.md) to get this URL.
NEXT_PUBLIC_INDEXER_URL=

# owner/repo of THIS project on GitHub — powers the landing page's self-referential
# "dogfooding" link once this repo is registered + anchored. Leave blank until then.
NEXT_PUBLIC_SELF_REPO=

NEXT_PUBLIC_RELAYER_ADDRESS=0x
# URL-friendly App name from its GitHub settings page — powers the "Connect GitHub"
# button's install link (github.com/apps/<slug>/installations/new). Public, not secret.
NEXT_PUBLIC_GITHUB_APP_SLUG=

# --- Server-only below: no NEXT_PUBLIC_ prefix, never shipped to the browser. ---
# Optional: a dedicated eth_getLogs-only endpoint (e.g. Envio's HyperRPC) for
# scanning event history fast — the public testnet RPC hard-caps eth_getLogs at
# 100 blocks; HyperRPC covers this app's entire history in ~200ms. The URL embeds
# the provider token, so it stays server-side; browsers scan via /api/scan.
# Falls back to NEXT_PUBLIC_RPC_URL if unset. Never used for contract reads or
# wallet writes (HyperRPC has no eth_call/eth_estimateGas/eth_sendRawTransaction).
SCAN_RPC_URL=
NOCAP_RELAYER_PRIVATE_KEY=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
